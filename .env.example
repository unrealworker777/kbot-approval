# ── Telegram-аккаунт Константина (my.telegram.org/apps) ──
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_PHONE=+79999999999

# ── Отдельный официальный бот-одобрятор (@BotFather → /newbot) ──
APPROVAL_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# твой numeric Telegram ID (узнать у @userinfobot). ОДИН РАЗ напиши боту в личку,
# иначе он не сможет написать первым.
APPROVAL_CHAT_ID=123456789

# ── Anthropic ──
# можно оставить пустым, если сделан `ant auth login`
ANTHROPIC_API_KEY=
# модель для черновиков (по умолчанию Haiku — быстро и дёшево)
DRAFT_MODEL=claude-haiku-4-5-20251001

# ── Что мониторить (юзернеймы без @, через запятую) ──
MONITORED_CHANNELS=channel_one,channel_two
MONITORED_CHATS=chat_one,chat_two

# ── Поведение ──
AUTO_REACT_EMOJI=👍
STYLE_PROFILE_PATH=style/style_profile.md
# off | non_contacts | all  (non_contacts = не трогать переписки с контактами)
DM_HANDLING=non_contacts
